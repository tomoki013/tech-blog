---
import type { Locale } from "@/i18n/config";
import { getUi } from "@/i18n/ui";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { formatDate } from "@/lib/seo";
import { siteConfig } from "@/site.config";

interface AlternateLocale {
  locale: Locale | "x-default";
  path: string;
}

interface Props {
  title: string;
  description: string;
  locale: Locale;
  canonicalPath: string;
  alternateHref: string;
  alternateLocales: AlternateLocale[];
  publishedAt: Date;
  updatedAt: Date;
  tags: string[];
}

const {
  title,
  description,
  locale,
  canonicalPath,
  alternateHref,
  alternateLocales,
  publishedAt,
  updatedAt,
  tags,
} = Astro.props;
const t = getUi(locale);
const articleUrl = `${siteConfig.url}${canonicalPath}`;
---

<BaseLayout
  title={title}
  description={description}
  locale={locale}
  canonicalPath={canonicalPath}
  alternateHref={alternateHref}
  type="article"
  alternateLocales={alternateLocales}
>
  <article class="article-detail">
    <header class="article-detail__header">
      <h2>{title}</h2>
      <div class="article-detail__profile">
        <img src={siteConfig.profileImage} alt={siteConfig.author} class="article-detail__avatar" />
        <div class="article-detail__author-info">
          <span class="article-detail__author-name">{siteConfig.author}</span>
          <p class="article-detail__author-bio">{siteConfig.bio[locale]}</p>
        </div>
      </div>
      <p class="article-detail__description">{description}</p>
      <div class="article-detail__dates">
        <time datetime={publishedAt.toISOString()}>{t.published}: {formatDate(publishedAt, locale)}</time>
        <time datetime={updatedAt.toISOString()}>{t.updated}: {formatDate(updatedAt, locale)}</time>
      </div>
      {tags.length > 0 && (
        <ul class="tag-list" aria-label={t.tags}>
          {tags.map((tag) => <li>{tag}</li>)}
        </ul>
      )}
      <div class="article-detail__share">
        <a
          href={`https://x.com/intent/tweet?url=${encodeURIComponent(articleUrl)}&text=${encodeURIComponent(title)}`}
          target="_blank"
          rel="noopener noreferrer"
          class="share-link"
          aria-label="Share on X"
          title="Share on X"
        >
          <svg
            class="share-icon"
            viewBox="0 0 24 24"
            fill="currentColor"
            xmlns="http://www.w3.org/2000/svg"
            aria-hidden="true"
          >
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24h-6.627l-5.1-6.694-5.867 6.694h-3.31l7.732-8.835L2.882 2.25h6.791l4.771 6.318 5.486-6.318zM17.002 18.807h1.844L6.983 3.931H5.025l11.977 14.876z" />
          </svg>
        </a>
      </div>
    </header>
    <div class="article-content">
      <slot />
    </div>
  </article>
</BaseLayout>

<style>
  .article-detail__share {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 1rem;
  }

  .share-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border-radius: 0.375rem;
    background-color: var(--color-surface-muted);
    color: var(--color-text);
    transition: all 0.2s ease-in-out;
  }

  .share-link:hover {
    background-color: var(--color-link);
    color: var(--color-surface);
  }

  .share-icon {
    width: 1.125rem;
    height: 1.125rem;
  }

  .dark .share-link {
    background-color: var(--color-surface-muted);
    color: var(--color-text);
  }

  .dark .share-link:hover {
    background-color: var(--color-link);
    color: var(--color-surface);
  }

  .article-detail__profile {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-top: 1.5rem;
    padding: 1rem;
    border: 1px solid var(--color-border);
    border-radius: 1rem;
    background-color: var(--color-surface);
  }

  .article-detail__avatar {
    width: 3.5rem;
    height: 3.5rem;
    border-radius: 999px;
    border: 1px solid var(--color-border);
    object-fit: cover;
  }

  .article-detail__author-info {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }

  .article-detail__author-name {
    font-weight: 700;
    font-size: 0.95rem;
  }

  .article-detail__author-bio {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    line-height: 1.5;
    margin: 0;
  }
</style>
