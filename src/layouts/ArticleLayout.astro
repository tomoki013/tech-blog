---
import type { Locale } from "@/i18n/config";
import { getUi } from "@/i18n/ui";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { formatDate } from "@/lib/seo";
import { siteConfig } from "@/site.config";

interface AlternateLocale {
  locale: Locale | "x-default";
  path: string;
}

interface Props {
  title: string;
  description: string;
  locale: Locale;
  canonicalPath: string;
  alternateHref: string;
  alternateLocales: AlternateLocale[];
  publishedAt: Date;
  updatedAt?: Date;
  tags: string[];
}

const {
  title,
  description,
  locale,
  canonicalPath,
  alternateHref,
  alternateLocales,
  publishedAt,
  updatedAt,
  tags,
} = Astro.props;
const t = getUi(locale);
const articleUrl = `${siteConfig.url}${canonicalPath}`;
---

<BaseLayout
  title={title}
  description={description}
  locale={locale}
  canonicalPath={canonicalPath}
  alternateHref={alternateHref}
  type="article"
  alternateLocales={alternateLocales}
>
  <article class="article-detail">
    <header class="article-detail__header">
      <h2>{title}</h2>
      <div class="article-detail__dates">
        <time datetime={publishedAt.toISOString()}>{t.published}: {formatDate(publishedAt, locale)}</time>
        {updatedAt && (
          <time datetime={updatedAt.toISOString()}>{t.updated}: {formatDate(updatedAt, locale)}</time>
        )}
      </div>
      <div class="article-detail__meta">
        {tags.length > 0 && (
          <ul class="tag-list" aria-label={t.tags}>
            {tags.map((tag) => <li>{tag}</li>)}
          </ul>
        )}
        <div class="article-detail__share">
          <a
            href={`https://x.com/intent/tweet?url=${encodeURIComponent(articleUrl)}&text=${encodeURIComponent(title)}`}
            target="_blank"
            rel="noopener noreferrer"
            class="share-link"
            aria-label="Share on X"
            title="Share on X"
          >
            <svg
              class="share-icon"
              viewBox="0 0 24 24"
              fill="currentColor"
              xmlns="http://www.w3.org/2000/svg"
              aria-hidden="true"
            >
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
            </svg>
          </a>
        </div>
      </div>
    </header>
    <div class="article-content">
      <slot />
    </div>
    <div class="article-detail__profile">
      <img
        src={siteConfig.profileImage}
        alt={siteConfig.author}
        class="article-detail__avatar"
        width="56"
        height="56"
        loading="lazy"
        decoding="async"
      />
      <div class="article-detail__author-info">
        <span class="article-detail__author-name">{siteConfig.author}</span>
        <p class="article-detail__author-bio">{siteConfig.bio[locale]}</p>
      </div>
    </div>
  </article>
</BaseLayout>

<style>
  .article-detail {
    width: min(100%, 46rem);
    margin-inline: auto;
  }

  .article-detail__header {
    margin-bottom: 2.25rem;
  }

  .article-detail__header h2 {
    margin: 0;
    font-size: clamp(2rem, 5vw, 2.8rem);
    line-height: 1.2;
    letter-spacing: -0.035em;
  }

  .article-detail__dates {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem 1rem;
    color: var(--color-text-muted);
    font-size: 0.9rem;
  }

  .article-detail__meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-top: 1rem;
  }

  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .tag-list li {
    border: 1px solid var(--color-border);
    border-radius: 999px;
    color: var(--color-text-muted);
    font-size: 0.82rem;
    padding: 0.25rem 0.56rem;
  }

  .article-detail__share {
    flex-shrink: 0;
  }

  .share-link {
    display: flex;
    align-items: center;
    color: var(--color-text-muted);
    transition: color 0.2s ease;
  }

  .share-link:hover {
    color: var(--color-text);
  }

  .share-icon {
    width: 1.15rem;
    height: 1.15rem;
  }

  .article-content {
    color: var(--color-text);
    font-size: 1.04rem;
    line-height: 1.95;
  }

  .article-content :global(> * + *) {
    margin-top: 1.25rem;
  }

  .article-content :global(h2),
  .article-content :global(h3),
  .article-content :global(h4) {
    margin-top: 2.5rem;
    line-height: 1.35;
    letter-spacing: -0.035em;
  }

  .article-content :global(h2) {
    font-size: 1.65rem;
  }

  .article-content :global(h3) {
    font-size: 1.32rem;
  }

  .article-content :global(p),
  .article-content :global(li) {
    color: color-mix(in srgb, var(--color-text) 88%, var(--color-text-muted));
  }

  .article-content :global(a) {
    color: var(--color-link);
  }

  .article-content :global(ul),
  .article-content :global(ol) {
    padding-left: 1.4rem;
  }

  .article-content :global(blockquote) {
    margin-inline: 0;
    border-left: 3px solid var(--color-border);
    padding-left: 1rem;
    color: var(--color-text-muted);
  }

  .article-content :global(code) {
    border: 1px solid var(--color-border);
    border-radius: 0.4rem;
    background: var(--color-surface-muted);
    padding: 0.12rem 0.34rem;
    font-size: 0.92em;
  }

  .article-content :global(pre) {
    overflow-x: auto;
    border: 1px solid var(--color-border);
    border-radius: 1rem;
    background: var(--color-surface-muted);
    padding: 1rem;
  }

  .article-content :global(pre code) {
    border: 0;
    background: transparent;
    padding: 0;
  }

  .article-detail__profile {
    display: flex;
    align-items: center;
    gap: 1.2rem;
    margin-top: 5rem;
    padding: 2.5rem;
    border: 1px solid var(--color-border);
    border-radius: 1.5rem;
    background: var(--color-surface);
    box-shadow: var(--shadow-soft);
  }

  .article-detail__avatar {
    border-radius: 999px;
    border: 1px solid var(--color-border);
  }

  .article-detail__author-name {
    display: block;
    font-weight: 700;
    font-size: 1.1rem;
    margin-bottom: 0.25rem;
  }

  .article-detail__author-bio {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    line-height: 1.5;
    margin: 0;
  }
</style>
