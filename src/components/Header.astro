---
import {
  getAboutPath,
  getArchivedPath,
  getArticlesPath,
  getHomePath,
  type Locale,
} from "@/i18n/config";
import { getUi } from "@/i18n/ui";
import { siteConfig } from "@/site.config";
import LanguageSwitcher from "./LanguageSwitcher.astro";
import ThemeToggle from "./ThemeToggle.astro";

interface Props {
  locale: Locale;
  alternateHref: string;
}

const { locale, alternateHref } = Astro.props;
const t = getUi(locale);
---

<header class="site-header">
  <div class="site-header__inner">
    <a class="site-header__brand" href={getHomePath(locale)} aria-label={siteConfig.name[locale]} data-astro-prefetch>
      <div class="site-header__brand-text">
        <span>{siteConfig.name[locale]}</span>
        <span class="site-header__author">{siteConfig.author}</span>
      </div>
    </a>

    <nav class="site-header__nav" aria-label="Primary navigation">
      <a href={getHomePath(locale)} data-astro-prefetch>{t.home}</a>
      <a href={getArticlesPath(locale)} data-astro-prefetch>{t.articles}</a>
      <a href={getArchivedPath(locale)} data-astro-prefetch>{t.archived}</a>
      <a href={getAboutPath(locale)} data-astro-prefetch>{t.about}</a>
    </nav>

    <div class="site-header__actions">
      <LanguageSwitcher locale={locale} alternateHref={alternateHref} />
      <ThemeToggle locale={locale} />
    </div>
  </div>
</header>

<style>
  .site-header__brand-text {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }

  .site-header__author {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    font-weight: normal;
  }
</style>
