---
import type { Locale } from "@/i18n/config";
import { getUi } from "@/i18n/ui";
import { formatDate } from "@/lib/seo";

interface Props {
  title: string;
  description: string;
  href: string;
  publishedAt: Date;
  tags: string[];
  locale: Locale;
  showTags?: boolean;
}

const { title, description, href, publishedAt, tags, locale, showTags = true } = Astro.props;
const t = getUi(locale);
---

<article class="article-card">
  <div class="article-card__meta">
    <time datetime={publishedAt.toISOString()}>{t.published}: {formatDate(publishedAt, locale)}</time>
  </div>
  <h2 class="article-card__title">
    <a href={href} data-astro-prefetch>{title}</a>
  </h2>
  <p class="article-card__description">{description}</p>
  {showTags && tags.length > 0 && (
    <ul class="tag-list" aria-label={t.tags}>
      {tags.map((tag) => <li>{tag}</li>)}
    </ul>
  )}
</article>

<style>
  .article-card {
    padding: 1.4rem;
    border: 1px solid var(--color-border);
    border-radius: 1.4rem;
    background: color-mix(in srgb, var(--color-surface) 92%, transparent);
    box-shadow: var(--shadow-soft);
  }

  .article-card__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem 1rem;
    color: var(--color-text-muted);
    font-size: 0.9rem;
  }

  .article-card__title {
    margin: 0.55rem 0 0;
    font-size: clamp(1.35rem, 3vw, 1.75rem);
    line-height: 1.25;
    letter-spacing: -0.035em;
  }

  .article-card__title a {
    color: var(--color-text);
    text-decoration: none;
  }

  .article-card__title a:hover {
    text-decoration: underline;
  }

  .article-card__description {
    margin: 0.7rem 0 0;
    color: var(--color-text-muted);
    line-height: 1.8;
  }

  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    padding: 0;
    margin: 1rem 0 0;
    list-style: none;
  }

  .tag-list li {
    border: 1px solid var(--color-border);
    border-radius: 999px;
    color: var(--color-text-muted);
    font-size: 0.82rem;
    padding: 0.25rem 0.56rem;
  }
</style>
