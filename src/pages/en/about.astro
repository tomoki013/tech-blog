---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { siteConfig } from "@/site.config";

const locale = "en";
---

<BaseLayout
  title="About"
  description="About Tomokichi and this blog, covering indie development, web engineering, AI-assisted work, product design, and operational improvements."
  locale={locale}
  canonicalPath="/en/about/"
  alternateHref="/about/"
  alternateLocales={[
    { locale: "ja", path: "/about/" },
    { locale: "en", path: "/en/about/" },
    { locale: "x-default", path: "/about/" },
  ]}
>
  <section class="page-header">
    <p class="eyebrow">About</p>
    <h2>About this blog</h2>
    <p>I write down what I learn from building, designing, operating, and improving software.</p>
  </section>

  <section class="about-card">
    <img
      class="hero__profile"
      src="/icon-256.webp"
      srcset="/icon-256.webp 256w, /icon-512.webp 512w"
      sizes="179px"
      alt="Tomokichi profile"
      width="179"
      height="179"
      loading="eager"
      fetchpriority="high"
      decoding="async"
    />
    <p>
      I am Tomokichi. This blog focuses on indie development, web engineering, AI-assisted development,
      product design, and operational improvements.
    </p>
    <p>
      I value not only polished conclusions, but also the messy process of learning and iteration.
    </p>
  </section>

  <section class="contact-cards">
    <a href="https://x.com/tomokichi178694" target="_blank" rel="noopener noreferrer" class="contact-card" aria-label="Contact on X">
      <div class="contact-card__icon">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
          <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
        </svg>
      </div>
      <div class="contact-card__content">
        <h3>Contact on X</h3>
        <p>@tomokichi178694</p>
      </div>
    </a>

    <a href="https://github.com/tomoki013/tech-blog/issues" target="_blank" rel="noopener noreferrer" class="contact-card" aria-label="Contact via Issues">
      <div class="contact-card__icon">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
        </svg>
      </div>
      <div class="contact-card__content">
        <h3>Contact via Issues</h3>
        <p>tech-blog</p>
      </div>
    </a>
  </section>
</BaseLayout>

<style>
  .about-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    text-align: center;
    margin-bottom: 3rem;
  }

  .about-card p {
    max-width: 42rem;
    color: var(--color-text-muted);
    font-size: 1.06rem;
    line-height: 1.85;
    margin: 0;
  }

  .about-card p + p {
    margin-top: 1.2rem;
  }

  .contact-cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(18rem, 1fr));
    gap: 1.5rem;
    margin-top: 3rem;
  }

  .contact-card {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    padding: 1.5rem;
    border: 1px solid var(--color-border);
    border-radius: 1rem;
    background: var(--color-surface);
    box-shadow: var(--shadow-soft);
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .contact-card:hover {
    border-color: var(--color-link);
    background: color-mix(in srgb, var(--color-surface) 90%, var(--color-link) 10%);
    box-shadow: 0 8px 24px rgb(28 27 24 / 0.12);
    transform: translateY(-2px);
  }

  .contact-card__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 3.5rem;
    height: 3.5rem;
    border-radius: 0.75rem;
    background: var(--color-surface-muted);
    color: var(--color-text);
    flex-shrink: 0;
  }

  .contact-card__content {
    flex: 1;
    text-align: left;
  }

  .contact-card__content h3 {
    margin: 0;
    font-size: 1.1rem;
    color: var(--color-text);
  }

  .contact-card__content p {
    margin: 0.35rem 0 0 0;
    font-size: 0.95rem;
    color: var(--color-text-muted);
  }
</style>
