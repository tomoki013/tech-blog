---
import ArticleCard from "@/components/ArticleCard.astro";
import { getUi } from "@/i18n/ui";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getArticlesWithPaths } from "@/lib/articles";

const locale = "en";
const t = getUi(locale);
const articles = await getArticlesWithPaths(locale);
---

<BaseLayout
  title={t.articles}
  description="Articles from Tomokichi's Engineering Growth Log."
  locale={locale}
  canonicalPath="/en/articles/"
  alternateHref="/articles/"
  alternateLocales={[
    { locale: "ja", path: "/articles/" },
    { locale: "en", path: "/en/articles/" },
    { locale: "x-default", path: "/articles/" },
  ]}
>
  <section class="page-header">
    <p class="eyebrow">Articles</p>
    <h1>{t.articles}</h1>
    <p>Notes on development, design, AI-assisted work, and operational improvements.</p>
  </section>

  <div class="article-list">
    {articles.length === 0 ? (
      <p>{t.noArticles}</p>
    ) : (
      articles.map(({ article, href }) => (
        <ArticleCard
          title={article.data.title}
          description={article.data.description}
          href={href}
          publishedAt={article.data.publishedAt}
          tags={article.data.tags}
          locale={locale}
          showTags={false}
        />
      ))
    )}
  </div>
</BaseLayout>

<style>
  .page-header {
    margin-bottom: 2.25rem;
  }

  .page-header h1 {
    margin: 0;
    font-size: clamp(2.35rem, 8vw, 5.2rem);
    line-height: 0.98;
    letter-spacing: -0.07em;
  }

  .page-header p {
    color: var(--color-text-muted);
    font-size: clamp(1.04rem, 2vw, 1.18rem);
    line-height: 1.9;
  }

  .eyebrow {
    margin: 0 0 0.8rem;
    color: var(--color-text-muted);
    font-size: 0.88rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .article-list {
    display: grid;
    gap: 1rem;
  }
</style>
