---
import ArticleCard from "@/components/ArticleCard.astro";
import { getArchivedPath } from "@/i18n/config";
import { getUi } from "@/i18n/ui";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getArticlesWithPaths } from "@/lib/articles";
import { siteConfig } from "@/site.config";

const locale = "en";
const t = getUi(locale);
const articles = (await getArticlesWithPaths(locale)).slice(0, 5);
---

<BaseLayout
  title={siteConfig.name[locale]}
  description={siteConfig.description[locale]}
  locale={locale}
  canonicalPath="/en/"
  alternateHref="/"
  alternateLocales={[
    { locale: "ja", path: "/" },
    { locale: "en", path: "/en/" },
    { locale: "x-default", path: "/" },
  ]}
>
  <section class="hero">
    <div>
      <p class="eyebrow">Engineering Growth Log</p>
      <h2>{siteConfig.name[locale]}</h2>
      <p>{t.topLead}</p>
    </div>
    <img
      class="hero__profile"
      src="/icon-256.webp"
      srcset="/icon-256.webp 256w, /icon-512.webp 512w"
      sizes="179px"
      alt="Tomokichi profile"
      width="179"
      height="179"
      loading="eager"
      fetchpriority="high"
      decoding="async"
    />
  </section>

  <section aria-labelledby="latest-articles">
    <div class="section-header">
      <h2 id="latest-articles">{t.latestArticles}</h2>
      <a href={getArchivedPath(locale)} data-astro-prefetch>{t.allArticles}</a>
    </div>
    <div class="article-list">
      {articles.length === 0 ? (
        <p>{t.noArticles}</p>
      ) : (
        articles.map(({ article, href }) => (
          <ArticleCard
            title={article.data.title}
            description={article.data.description}
            href={href}
            publishedAt={article.data.publishedAt}
            tags={article.data.tags}
            locale={locale}
          />
        ))
      )}
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 2rem;
    align-items: center;
    margin-bottom: 4rem;
  }

  .hero h2 {
    margin: 0;
    font-size: clamp(1.6rem, 4vw, 2.2rem);
    line-height: 1.2;
    letter-spacing: -0.035em;
  }

  .hero p {
    max-width: 42rem;
    color: var(--color-text-muted);
    font-size: clamp(1.04rem, 2vw, 1.18rem);
    line-height: 1.9;
  }

  .hero__profile {
    width: 179px;
    height: 179px;
    border-radius: 9999px;
    object-fit: cover;
  }

  .eyebrow {
    margin: 0 0 0.8rem;
    color: var(--color-text-muted);
    font-size: 0.88rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .section-header {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .section-header h2 {
    margin: 0;
    font-size: clamp(1.6rem, 4vw, 2.2rem);
    line-height: 1.2;
    letter-spacing: -0.035em;
  }

  .section-header a {
    color: var(--color-text-muted);
    font-size: 0.95rem;
  }

  .article-list {
    display: grid;
    gap: 1rem;
  }

  @media (max-width: 760px) {
    .hero {
      grid-template-columns: 1fr;
    }

    .section-header {
      align-items: flex-start;
      flex-direction: column;
    }
  }
</style>
