---
import { getUi } from "@/i18n/ui";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getArticlesWithPaths } from "@/lib/articles";

const locale = "ja";
const t = getUi(locale);
const articles = await getArticlesWithPaths(locale);

const articlesByYear = articles.reduce(
  (acc, { article, slug, href }) => {
    const year = article.data.publishedAt.getFullYear();
    if (!acc[year]) {
      acc[year] = [];
    }
    acc[year].push({ article, slug, href });
    return acc;
  },
  {} as Record<number, typeof articles>,
);

const years = Object.keys(articlesByYear)
  .map(Number)
  .sort((a, b) => b - a);
---

<BaseLayout
  title={t.archived}
  description="ともきちのエンジニア成長記の記事アーカイブです。年別に記事をまとめています。"
  locale={locale}
  canonicalPath="/archived/"
  alternateHref="/en/archived/"
  alternateLocales={[
    { locale: "ja", path: "/archived/" },
    { locale: "en", path: "/en/archived/" },
    { locale: "x-default", path: "/archived/" },
  ]}
>
  <section class="page-header">
    <p class="eyebrow">Archive</p>
    <h1>{t.archived}</h1>
    <p>過去に執筆した記事のアーカイブです。</p>
  </section>

  <div class="archive-list">
    {years.length === 0 ? (
      <p>{t.noArticles}</p>
    ) : (
      years.map((year) => (
        <section class="archive-year">
          <h2>{year}</h2>
          <ol>
            {articlesByYear[year].map(({ article, href }) => (
              <li>
                <time datetime={article.data.publishedAt.toISOString()}>
                  {article.data.publishedAt.toLocaleDateString(locale, {
                    month: "2-digit",
                    day: "2-digit",
                    hour: "2-digit",
                    minute: "2-digit",
                  })}
                </time>
                <a href={href}>{article.data.title}</a>
              </li>
            ))}
          </ol>
        </section>
      ))
    )}
  </div>
</BaseLayout>

<style>
  .page-header {
    margin-bottom: 2.25rem;
  }

  .page-header h1 {
    margin: 0;
    font-size: clamp(2.35rem, 8vw, 5.2rem);
    line-height: 0.98;
    letter-spacing: -0.07em;
  }

  .page-header p {
    color: var(--color-text-muted);
    font-size: clamp(1.04rem, 2vw, 1.18rem);
    line-height: 1.9;
  }

  .eyebrow {
    margin: 0 0 0.8rem;
    color: var(--color-text-muted);
    font-size: 0.88rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .archive-list {
    display: grid;
    gap: 2rem;
  }

  .archive-year {
    padding: 1.4rem;
    border: 1px solid var(--color-border);
    border-radius: 1.4rem;
    background: color-mix(in srgb, var(--color-surface) 92%, transparent);
    box-shadow: var(--shadow-soft);
  }

  .archive-year h2 {
    margin: 0 0 1rem;
    font-size: 1.45rem;
    letter-spacing: -0.04em;
  }

  .archive-year ol {
    display: grid;
    gap: 0.85rem;
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .archive-year li {
    display: grid;
    grid-template-columns: 8rem minmax(0, 1fr);
    gap: 1rem;
    align-items: baseline;
  }

  .archive-year time {
    color: var(--color-text-muted);
    font-size: 0.9rem;
  }

  .archive-year a {
    color: var(--color-text);
    font-weight: 650;
    text-decoration: none;
  }

  .archive-year a:hover {
    text-decoration: underline;
  }

  @media (max-width: 760px) {
    .archive-year li {
      grid-template-columns: 1fr;
      gap: 0.2rem;
    }
  }
</style>
